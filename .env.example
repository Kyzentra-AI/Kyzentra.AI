# Cloudflare Turnstile Site Key (used by the frontend widget)
# Use Cloudflare's always-pass test key for development/testing: 1x00000000000000000000AA
# Replace with your real site key for production (after adding your domain to Turnstile widget's allowed hostnames)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Google Apps Script Web App URL (used directly by the frontend to submit form data)
VITE_APPS_SCRIPT_URL=your_google_apps_script_web_app_url
